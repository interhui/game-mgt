{
  "name": "game-mgt",
  "version": "1.0.0",
  "description": "基于 Electron 的模拟器游戏管理程序",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dev": "electron . --enable-logging",
    "build": "electron-builder --win",
    "test": "jest"
  },
  "keywords": [
    "game",
    "emulator",
    "electron",
    "manager"
  ],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.9.1",
    "jest": "^29.7.0"
  },
  "dependencies": {
    "electron-log": "^5.0.0"
  },
  "build": {
    "appId": "com.gamemgt.app",
    "productName": "GameManager",
    "directories": {
      "output": "dist"
    },
    "win": {
      "target": [
        "nsis"
      ],
      "icon": "assets/icon.ico"
    }
  }
}
